#!/usr/bin/env bash
# claude-peon — Warcraft peon voice + icon notifications for Claude Code hooks.
# Commands: install | build | test | status | uninstall | help
set -euo pipefail

# Resolve our own real location, following symlinks (so a PATH symlink still
# finds the share scripts next to the real CLI). The counter guards against a
# symlink loop turning this into an infinite loop.
SRC="${BASH_SOURCE[0]:-$0}"
_hops=0
while [[ -L "$SRC" ]]; do
  _hops=$((_hops + 1)); [[ $_hops -gt 40 ]] && break
  d="$(cd "$(dirname "$SRC")" && pwd)"
  SRC="$(readlink "$SRC")"
  [[ "$SRC" != /* ]] && SRC="$d/$SRC"
done
SELF="$(cd "$(dirname "$SRC")" && pwd)"
CLI_SRC="$SRC"

# Locate the share dir: repo layout (bin/ + share/), or the flat installed
# layout where the CLI lives in ~/.claude/peon alongside the scripts.
if   [[ -d "$SELF/../share" ]]; then SHARE="$(cd "$SELF/../share" && pwd)"
elif [[ -d "$SELF/share"    ]]; then SHARE="$SELF/share"
else                                 SHARE="$SELF"; fi
# Bundled assets only exist in the repo layout (…/share/../assets). In the flat
# installed layout this would resolve to ~/.claude/assets, so don't look there.
if [[ "$(basename "$SHARE")" == "share" ]]; then
  ASSETS_DIR="$(cd "$SHARE/.." 2>/dev/null && pwd)/assets"
else
  ASSETS_DIR=""
fi

DEST="$HOME/.claude/peon"
SETTINGS="$HOME/.claude/settings.json"

c_green=$'\033[32m'; c_yellow=$'\033[33m'; c_dim=$'\033[2m'; c_reset=$'\033[0m'
ok()   { echo "${c_green}✓${c_reset} $*"; }
warn() { echo "${c_yellow}!${c_reset} $*"; }
step() { echo "${c_dim}→ $*${c_reset}"; }

require_macos() {
  [[ "$(uname)" == "Darwin" ]] || { echo "claude-peon is macOS-only." >&2; exit 1; }
}

# Symlink the installed CLI onto the first writable directory already on PATH.
link_cli() {
  local target="$DEST/claude-peon" d link
  for d in /opt/homebrew/bin /usr/local/bin "$HOME/.local/bin"; do
    case ":$PATH:" in *":$d:"*) ;; *) continue ;; esac
    [[ -d "$d" && -w "$d" ]] || continue
    link="$d/claude-peon"
    if [[ -e "$link" || -L "$link" ]]; then
      # Reuse our own link, but never clobber a different existing command.
      if [[ -L "$link" && "$(readlink "$link")" == "$target" ]]; then
        ok "Already linked -> $link"; return 0
      fi
      warn "Skipping $link — a different file already lives there."
      continue
    fi
    if ln -s "$target" "$link" 2>/dev/null; then
      ok "Linked claude-peon -> $link"; return 0
    fi
  done
  warn "Couldn't link onto PATH. Run it via:  $target"
  warn "or add to PATH:  export PATH=\"\$HOME/.claude/peon:\$PATH\""
}

SUPPORTED_LANGS="en ru de es fr"

lang_supported() {
  local l="$1" x
  for x in $SUPPORTED_LANGS; do [[ "$x" == "$l" ]] && return 0; done
  return 1
}

# Copy a language pack's sounds + phrases into the active slots.
activate_lang() {
  local lang="$1" src="$DEST/lang/$lang"
  [[ -d "$src" ]] || { echo "Language pack '$lang' not found in $DEST/lang." >&2; return 1; }
  mkdir -p "$DEST/sounds"
  rm -f "$DEST"/sounds/done.* "$DEST"/sounds/wait*.* 2>/dev/null || true
  cp "$src"/*.wav "$DEST/sounds/"
  cp "$src/phrases.sh" "$DEST/phrases.sh"
  printf '%s' "$lang" > "$DEST/lang.current"
}

cmd_install() {
  require_macos
  local lang="en"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --lang)   lang="${2:-}"; shift 2 ;;
      --lang=*) lang="${1#*=}"; shift ;;
      *) echo "Unknown option: $1 (try: claude-peon install --lang <code>)" >&2; exit 1 ;;
    esac
  done
  if ! lang_supported "$lang"; then
    echo "Unsupported language '$lang'. Available: $SUPPORTED_LANGS" >&2; exit 1
  fi

  step "Installing into $DEST"
  mkdir -p "$DEST"

  install -m 0644 "$SHARE/peon.applescript" "$DEST/peon.applescript"
  install -m 0755 "$SHARE/notify.sh"        "$DEST/notify.sh"
  install -m 0755 "$SHARE/build-app.sh"     "$DEST/build-app.sh"
  install -m 0644 "$SHARE/merge-hooks.js"   "$DEST/merge-hooks.js"
  [[ -f "$DEST/config.sh" ]] || install -m 0644 "$SHARE/config.sh.example" "$DEST/config.sh"

  # Install the CLI itself so it's self-contained and linkable onto PATH.
  if [[ "$CLI_SRC" != "$DEST/claude-peon" ]]; then
    install -m 0755 "$CLI_SRC" "$DEST/claude-peon"
  fi
  ok "Copied scripts + CLI"

  # Bundle every language pack + the icon (repo layout only), so switching later
  # with `claude-peon lang <code>` works without the repo checkout.
  if [[ -n "$ASSETS_DIR" && -d "$ASSETS_DIR" ]]; then
    [[ -d "$ASSETS_DIR/lang" ]] && { mkdir -p "$DEST/lang"; cp -R "$ASSETS_DIR/lang/." "$DEST/lang/"; }
    for f in peon.png peon.jpg peon.jpeg; do
      [[ -f "$ASSETS_DIR/$f" && ! -e "$DEST/$f" ]] && cp "$ASSETS_DIR/$f" "$DEST/$f"
    done
  fi

  if [[ -d "$DEST/lang/$lang" ]]; then
    step "Activating voice pack: $lang"
    activate_lang "$lang"
    ok "Language: $lang"
  else
    warn "No bundled sounds for '$lang' — notifications will be silent until added."
  fi

  local img
  img="$(/bin/ls "$DEST"/peon.png "$DEST"/peon.jpg "$DEST"/peon.jpeg 2>/dev/null | /usr/bin/head -1 || true)"
  if [[ -n "$img" ]]; then
    step "Building Peon.app with the icon"
    bash "$DEST/build-app.sh"
  else
    warn "No image yet — drop peon.png (or .jpg) into $DEST, then run: claude-peon build"
  fi

  step "Wiring Stop / Notification hooks into $SETTINGS"
  mkdir -p "$(dirname "$SETTINGS")"
  osascript -l JavaScript "$DEST/merge-hooks.js" "$SETTINGS" add >/dev/null
  ok "Hooks installed"

  step "Linking the claude-peon command onto your PATH"
  link_cli

  echo
  ok "Done. One manual step remains:"
  echo "   Enable banners for \"Peon\": System Settings → Notifications → Peon"
  echo "   → Allow Notifications, style Banners or Alerts."
  step "Opening Notification settings…"
  open "x-apple.systempreferences:com.apple.Notifications-Settings.extension" 2>/dev/null \
    || open "x-apple.systempreferences:com.apple.preference.notifications" 2>/dev/null || true
  echo
  echo "Then verify with:  claude-peon test"
}

cmd_lang() {
  require_macos
  local lang="${1:-}"
  local avail; avail="$([[ -d "$DEST/lang" ]] && (cd "$DEST/lang" && echo *) || echo "$SUPPORTED_LANGS")"
  if [[ -z "$lang" ]]; then
    local cur="(unknown)"; [[ -f "$DEST/lang.current" ]] && cur="$(cat "$DEST/lang.current")"
    echo "Current language : $cur"
    echo "Available        : $avail"
    echo "Switch with      : claude-peon lang <code>"
    return 0
  fi
  if [[ ! -d "$DEST/lang/$lang" ]]; then
    echo "Language '$lang' not installed. Available: $avail" >&2; exit 1
  fi
  activate_lang "$lang"
  ok "Switched to '$lang' — new phrases and voice are live."
}

cmd_build()  { require_macos; bash "$DEST/build-app.sh"; }

cmd_test() {
  require_macos
  [[ -x "$DEST/notify.sh" ]] || { echo "Not installed. Run: claude-peon install" >&2; exit 1; }
  step "Firing 'done'…"; bash "$DEST/notify.sh" done; sleep 3
  step "Firing 'wait'…"; bash "$DEST/notify.sh" wait
  ok "If you saw two banners (and heard sound where present), you're set."
}

cmd_status() {
  echo "share dir : $SHARE"
  echo "dest dir  : $DEST"
  local cur="(unknown)"; [[ -f "$DEST/lang.current" ]] && cur="$(cat "$DEST/lang.current")"
  echo "language  : $cur"
  [[ -d "$DEST/Peon.app" ]] && ok "Peon.app built" || warn "Peon.app missing (run: claude-peon build)"
  /bin/ls "$DEST"/sounds/done.*  >/dev/null 2>&1 && ok "done sound present" || warn "no done sound"
  /bin/ls "$DEST"/sounds/wait1.* >/dev/null 2>&1 && ok "wait sounds present" || warn "no wait sounds"
  if [[ -f "$SETTINGS" ]] && grep -q "peon/notify.sh" "$SETTINGS" 2>/dev/null; then
    ok "hooks present in settings.json"
  else
    warn "hooks not found in settings.json (run: claude-peon install)"
  fi
}

cmd_pause() {
  require_macos
  local merge="$DEST/merge-hooks.js"; [[ -f "$merge" ]] || merge="$SHARE/merge-hooks.js"
  if [[ -f "$SETTINGS" ]]; then
    local err
    if ! err="$(osascript -l JavaScript "$merge" "$SETTINGS" remove 2>&1)"; then
      echo "ERROR: couldn't update $SETTINGS — hooks NOT removed:" >&2
      echo "  $err" >&2
      exit 1
    fi
  fi
  ok "Paused — hooks removed from settings.json, no notifications will fire."
  echo "   Everything stays installed. Turn it back on with:  claude-peon resume"
}

cmd_resume() {
  require_macos
  local merge="$DEST/merge-hooks.js"; [[ -f "$merge" ]] || merge="$SHARE/merge-hooks.js"
  mkdir -p "$(dirname "$SETTINGS")"
  osascript -l JavaScript "$merge" "$SETTINGS" add >/dev/null
  ok "Resumed — hooks re-added. Notifications are back."
}

cmd_uninstall() {
  require_macos
  step "Removing hooks from settings.json"
  local merge="$DEST/merge-hooks.js"; [[ -f "$merge" ]] || merge="$SHARE/merge-hooks.js"
  # Abort BEFORE deleting scripts if hooks can't be removed — otherwise the hooks
  # would linger in settings.json pointing at files we just rm -rf'd, and every
  # Stop/Notification in Claude Code would error.
  if [[ -f "$SETTINGS" ]]; then
    local err
    if ! err="$(osascript -l JavaScript "$merge" "$SETTINGS" remove 2>&1)"; then
      echo "ERROR: couldn't remove hooks from $SETTINGS:" >&2
      echo "  $err" >&2
      echo "Fix that first (or edit the file by hand); aborting to avoid dangling hooks." >&2
      exit 1
    fi
  fi
  step "Removing PATH symlinks"
  local d target="$DEST/claude-peon"
  for d in /opt/homebrew/bin /usr/local/bin "$HOME/.local/bin"; do
    [[ -L "$d/claude-peon" ]] || continue
    # Only remove a link we created (points at our CLI) — never a stranger's binary.
    [[ "$(readlink "$d/claude-peon")" == "$target" ]] && rm -f "$d/claude-peon"
  done
  step "Removing $DEST"
  rm -rf "$DEST"
  ok "Uninstalled. (Notification permission entry for 'Peon' stays in System Settings.)"
}

usage() {
  cat <<EOF
claude-peon — Warcraft peon notifications for Claude Code (macOS)

  claude-peon install [--lang <code>]   Install (default: en), build app, wire hooks, link to PATH
  claude-peon lang [<code>]             Show / switch voice language ($SUPPORTED_LANGS)
  claude-peon build                     Rebuild Peon.app from the current image
  claude-peon test                      Fire both notifications
  claude-peon status                    Show what's installed
  claude-peon pause                     Stop notifications (remove hooks), keep everything installed
  claude-peon resume                    Re-enable notifications after a pause
  claude-peon uninstall                 Remove hooks, ~/.claude/peon, and the PATH symlink
  claude-peon help                      This help

Languages: $SUPPORTED_LANGS. Phrase/behavior overrides: ~/.claude/peon/config.sh.
EOF
}

cmd="${1:-help}"; [[ $# -gt 0 ]] && shift
case "$cmd" in
  install)   cmd_install "$@" ;;
  lang)      cmd_lang "$@" ;;
  build)     cmd_build ;;
  test)      cmd_test ;;
  status)    cmd_status ;;
  pause)     cmd_pause ;;
  resume)    cmd_resume ;;
  uninstall) cmd_uninstall ;;
  ""|help|-h|--help) usage ;;
  *) echo "Unknown command: $cmd" >&2; usage; exit 1 ;;
esac
